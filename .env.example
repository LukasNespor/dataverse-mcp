# Copy this file to .env and fill in your values

# Required: your Dataverse / Power Platform environment URL
# Find this in Power Platform Admin Center → Environments → your env → Environment URL
DATAVERSE_URL=https://yourorg.crm4.dynamics.com

# Optional: your Azure AD tenant ID
# Find this in Azure Portal → Azure Active Directory → Overview → Tenant ID
# Leave as "common" if you are unsure — it works for most single-tenant organizations
# IMPORTANT: Azure OBO mode requires the tenant GUID (e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx),
# not a domain name (e.g. contoso.com). The domain form works for endpoints but the JWT issuer
# claim always uses the GUID, causing token validation to fail.
TENANT_ID=common

# Required: Azure AD Application (client) ID from your Entra ID app registration.
# Register an app in Azure Portal → Microsoft Entra ID → App registrations.
# Add "Dynamics CRM > user_impersonation" delegated permission.
# For interactive auth, add redirect URI: http://localhost:5577 (Public client/native).
CLIENT_ID=your-client-id-here

# Optional: port for the interactive auth redirect server. Default is 5577.
# After signing in, the browser redirects to http://localhost:<port>.
# This port is published in docker-compose so the redirect reaches the container.
# AUTH_REDIRECT_PORT=5577

# --- Azure OBO mode (multi-user) ---
# Set CLIENT_SECRET to activate OBO mode. When set, the server uses Entra ID
# On-Behalf-Of flow instead of interactive browser auth.
# CLIENT_SECRET=your-client-secret-here

# Public URL where the MCP server is reachable (used for OAuth redirect).
# For local testing: http://localhost:8000 (default)
# For Azure deployment: https://your-app.azurewebsites.net
# MCP_BASE_URL=http://localhost:8000

# Redis connection string (required)
# Local Docker: redis://redis:6379/0
# Azure Redis: rediss://:<access-key>@<host>:6380/0
# REDIS_URL=redis://redis:6379/0
