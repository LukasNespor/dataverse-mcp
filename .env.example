# Copy this file to .env and fill in your values

# Required: your Dataverse / Power Platform environment URL
# Find this in Power Platform Admin Center → Environments → your env → Environment URL
DATAVERSE_URL=https://yourorg.crm4.dynamics.com

# Required: your Azure AD tenant ID (must be the GUID, not a domain name)
# Find this in Azure Portal → Azure Active Directory → Overview → Tenant ID
# IMPORTANT: The JWT issuer claim always uses the GUID, so using a domain name
# (e.g. contoso.com) will cause token validation to fail.
TENANT_ID=common

# Required: Azure AD Application (client) ID from your Entra ID app registration.
# Register an app in Azure Portal → Microsoft Entra ID → App registrations.
# Add "Dynamics CRM > user_impersonation" delegated permission.
CLIENT_ID=your-client-id-here

# Required: Azure AD Application (client) secret from your Entra ID app registration.
# Certificates & secrets → New client secret → copy the value here.
CLIENT_SECRET=your-client-secret-here

# Public URL where the MCP server is reachable (used for OAuth redirect).
# For local testing: http://localhost:8000 (default)
# For Azure deployment: https://your-app.azurewebsites.net
# MCP_BASE_URL=http://localhost:8000

# Redis connection string (required)
# Local Docker: redis://redis:6379/0 (set automatically by docker-compose)
# Azure Redis: rediss://:<access-key>@<host>:6380/0
REDIS_URL=redis://redis:6379/0

# --- Session persistence ---
# These keys persist OAuth session state across container restarts.
# Both must remain stable across deployments — rotating them invalidates all active sessions.
#
# Generate JWT_SIGNING_KEY:         python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate STORAGE_ENCRYPTION_KEY:  python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
#
# JWT_SIGNING_KEY=
# STORAGE_ENCRYPTION_KEY=
